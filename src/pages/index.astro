---
import ListingModerator from '../components/ListingModerator.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Listing Moderator — powered by Seclai</title>
    <meta name="description" content="Upload a marketplace listing photo and check it against listing policies — approve, review, or reject with violations and quality score." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <ListingModerator client:load />

    <style is:global>
      :root {
        --accent: #4f46e5;
        --accent-hover: #4338ca;
        --accent-soft: #eef2ff;
        --bg: #f8fafc;
        --surface: #ffffff;
        --ink: #0f172a;
        --ink-soft: #475569;
        --ink-muted: #94a3b8;
        --line: #e2e8f0;
        --line-strong: #cbd5e1;
        --good: #16a34a;
        --warn: #d97706;
        --bad: #dc2626;
        --font: 'Geist', -apple-system, system-ui, sans-serif;
        --mono: 'Geist Mono', ui-monospace, 'SF Mono', monospace;
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; height: 100%; }
      body {
        font-family: var(--font);
        background: var(--bg);
        color: var(--ink);
        -webkit-font-smoothing: antialiased;
      }
      @keyframes mp-spin { to { transform: rotate(360deg); } }
      @keyframes mp-fade { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }
      ::-webkit-scrollbar { width: 10px; height: 10px; }
      ::-webkit-scrollbar-thumb { background: var(--line); border-radius: 8px; border: 3px solid #fff; }

      .app { min-height: 100vh; display: flex; flex-direction: column; background: var(--bg); }

      /* ---- Top bar ---- */
      .topbar {
        flex: none; height: 60px; background: var(--surface); border-bottom: 1px solid var(--line);
        display: flex; align-items: center; justify-content: space-between; padding: 0 24px;
        position: sticky; top: 0; z-index: 30;
      }
      .brand { display: flex; align-items: center; gap: 12px; }
      .brand-mark {
        width: 30px; height: 30px; border-radius: 8px; background: var(--accent);
        display: flex; align-items: center; justify-content: center; box-shadow: 0 1px 3px rgba(15,23,42,0.12);
      }
      .brand-diamond { width: 11px; height: 11px; border-radius: 3px; background: #fff; transform: rotate(45deg); }
      .brand-title { font-size: 15px; font-weight: 600; letter-spacing: -0.01em; color: var(--ink); white-space: nowrap; }
      .brand-pill {
        font-family: var(--mono); font-size: 10.5px; font-weight: 500; color: var(--ink-soft);
        background: #f1f5f9; border: 1px solid var(--line); border-radius: 999px; padding: 2px 8px; white-space: nowrap;
        text-decoration: none; cursor: pointer;
        transition: color .15s, background .15s, border-color .15s, transform .15s;
      }
      a.brand-pill:hover, a.brand-pill:focus-visible {
        color: var(--accent); background: var(--accent-soft); border-color: var(--accent);
        transform: translateY(-1px); outline: none;
      }

      .gh-btn {
        display: inline-flex; align-items: center; gap: 6px;
        height: 32px; padding: 0 12px; border-radius: 8px;
        border: 1px solid var(--line); background: var(--surface); color: var(--ink-soft);
        font-family: var(--font); font-size: 12.5px; font-weight: 500;
        text-decoration: none; white-space: nowrap;
        transition: color .15s, background .15s, border-color .15s, box-shadow .15s;
      }
      .gh-btn:hover, .gh-btn:focus-visible {
        color: var(--ink); background: #f8fafc; border-color: var(--line-strong);
        box-shadow: 0 1px 3px rgba(15,23,42,0.08); outline: none;
      }
      .gh-btn svg { display: block; }

      /* ---- Hero ---- */
      .hero {
        flex: none; background: var(--surface); border-bottom: 1px solid var(--line);
        padding: 44px 24px 40px;
        display: flex; flex-direction: column; align-items: center; text-align: center; gap: 14px;
      }
      .hero-pill {
        display: inline-flex; align-items: center; gap: 8px;
        font-size: 12.5px; font-weight: 500; color: var(--ink-soft);
        background: #f1f5f9; border: 1px solid var(--line);
        border-radius: 999px; padding: 6px 13px;
      }
      .hero-pill-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--good); box-shadow: 0 0 0 3px rgba(22,163,74,0.15); }
      .hero-title {
        margin: 4px 0 0; font-size: 38px; line-height: 1.08; font-weight: 700;
        letter-spacing: -0.028em; color: var(--ink); max-width: 720px;
      }
      .hero-sub {
        margin: 0; font-size: 15px; line-height: 1.55; color: var(--ink-soft); max-width: 600px;
      }
      @media (max-width: 640px) {
        .topbar { padding: 0 14px; }
        .brand-pill { display: none; }
        .checks-btn span, .gh-btn span { display: none; }
        .checks-btn, .gh-btn { padding: 0 9px; }
        .hero { padding: 28px 20px 24px; }
        .hero-title { font-size: 26px; }
        .hero-sub { font-size: 13.5px; }
        .hero-title br { display: none; }
      }

      /* ---- Main / layout ---- */
      .main { flex: 1; min-height: 0; display: flex; justify-content: center; padding: 24px; }
      .layout { width: 100%; max-width: 1180px; display: flex; gap: 24px; min-height: 0; }

      .panel { background: var(--surface); border: 1px solid var(--line); border-radius: 12px; box-shadow: 0 1px 3px rgba(15,23,42,0.08); }
      .panel-label { font-size: 12px; font-weight: 600; letter-spacing: 0.02em; text-transform: uppercase; color: var(--ink-muted); }

      .input-panel { flex: none; width: 400px; padding: 24px; display: flex; flex-direction: column; }
      .input-panel .panel-label { margin-bottom: 14px; }

      /* ---- Dropzone / preview ---- */
      .drop {
        border: 1.5px dashed var(--line-strong); background: var(--surface); border-radius: 10px;
        padding: 30px 20px; display: flex; flex-direction: column; align-items: center; gap: 12px; cursor: pointer;
        transition: border-color .15s, background .15s;
      }
      .drop:hover, .drop:focus-visible { border-color: var(--accent); outline: none; }
      .drop.over { border-color: var(--accent); background: var(--accent-soft); }
      .drop-icon { width: 42px; height: 42px; border-radius: 10px; background: var(--accent-soft); display: flex; align-items: center; justify-content: center; }
      .drop-text { text-align: center; }
      .drop-title { font-size: 13.5px; font-weight: 500; color: var(--ink-soft); }
      .drop-sub { font-size: 12px; color: var(--ink-muted); margin-top: 3px; }

      .preview { position: relative; border-radius: 10px; overflow: hidden; border: 1px solid var(--line); background: #0f172a; }
      .preview-img { width: 100%; height: 200px; background-color: #0f172a; background-size: contain; background-repeat: no-repeat; background-position: center; }
      .preview-clear {
        position: absolute; top: 8px; right: 8px; width: 26px; height: 26px; border-radius: 7px; border: none;
        background: rgba(15,23,42,0.6); color: #fff; cursor: pointer; font-size: 13px; display: flex; align-items: center; justify-content: center;
      }
      .preview-name {
        position: absolute; left: 8px; bottom: 8px; font-family: var(--mono); font-size: 10.5px; color: #fff;
        background: rgba(15,23,42,0.6); border-radius: 6px; padding: 3px 8px; max-width: 80%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }

      /* ---- Caption + run ---- */
      .field-label { display: block; font-size: 12.5px; font-weight: 500; color: var(--ink-soft); margin: 18px 0 6px; }
      .field-optional { color: var(--ink-muted); font-weight: 400; }
      .caption-input {
        width: 100%; height: 40px; padding: 0 12px; border: 1px solid var(--line); border-radius: 8px;
        font-family: var(--font); font-size: 13.5px; color: var(--ink); outline: none; background: #fff;
      }
      .caption-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-soft); }
      .field-helper { margin-top: 7px; font-size: 11.5px; line-height: 1.45; color: var(--ink-muted); }

      .run-btn {
        margin-top: 18px; height: 44px; width: 100%; background: var(--accent); color: #fff; border: none; border-radius: 8px;
        font-family: var(--font); font-size: 14px; font-weight: 600; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;
        box-shadow: 0 1px 3px rgba(79,70,229,0.35); transition: background .15s;
      }
      .run-btn:hover:not(:disabled) { background: var(--accent-hover); }
      .run-btn:disabled { opacity: 0.55; cursor: not-allowed; }
      .run-spinner { width: 15px; height: 15px; border: 2px solid rgba(255,255,255,0.4); border-top-color: #fff; border-radius: 50%; display: inline-block; animation: mp-spin .7s linear infinite; }
      .run-hint { margin-top: 10px; font-size: 11.5px; color: var(--ink-muted); text-align: center; }

      /* ---- Output panel ---- */
      .output-panel { flex: 1; min-width: 0; display: flex; flex-direction: column; min-height: 0; }
      .output-header { flex: none; height: 56px; border-bottom: 1px solid var(--line); display: flex; align-items: center; justify-content: space-between; padding: 0 20px; }
      .tabs { display: flex; background: #f1f5f9; border-radius: 8px; padding: 3px; gap: 2px; }
      .tab {
        height: 28px; padding: 0 16px; border: none; border-radius: 6px; font-family: var(--font); font-size: 12.5px; font-weight: 600;
        cursor: pointer; background: transparent; color: var(--ink-soft);
      }
      .tab-mono { font-family: var(--mono); font-size: 12px; font-weight: 500; }
      .tab.active { background: #fff; color: var(--ink); box-shadow: 0 1px 2px rgba(15,23,42,0.10); }

      .output-body { flex: 1; min-height: 0; overflow: auto; }

      .placeholder { height: 100%; min-height: 340px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14px; padding: 40px; text-align: center; }
      .placeholder-icon { width: 48px; height: 48px; border-radius: 12px; background: #f1f5f9; display: flex; align-items: center; justify-content: center; }
      .placeholder-text { font-size: 13.5px; color: var(--ink-muted); max-width: 360px; line-height: 1.5; }
      .big-spinner { width: 26px; height: 26px; border: 3px solid var(--line); border-top-color: var(--accent); border-radius: 50%; display: inline-block; animation: mp-spin .7s linear infinite; }
      .loading-text { font-family: var(--mono); font-size: 12px; color: var(--ink-muted); }

      /* ---- Card view ---- */
      .card-view { padding: 24px; animation: mp-fade .2s ease; }
      .verdict { display: flex; align-items: center; gap: 16px; border: 1px solid; border-radius: 12px; padding: 18px 20px; }
      .verdict-glyph { width: 44px; height: 44px; border-radius: 11px; display: flex; align-items: center; justify-content: center; flex: none; color: #fff; font-size: 20px; line-height: 1; }
      .verdict-label { font-size: 22px; font-weight: 700; letter-spacing: -0.02em; line-height: 1.1; }
      .verdict-sub { font-size: 13px; color: var(--ink-soft); margin-top: 3px; }

      .section { margin-top: 22px; }
      .section-label { font-size: 12px; font-weight: 600; letter-spacing: 0.02em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 10px; }
      .muted { color: var(--line-strong); }

      .violation-list { display: flex; flex-direction: column; gap: 8px; }
      .violation { display: flex; align-items: flex-start; gap: 12px; border: 1px solid var(--line); border-radius: 10px; padding: 12px 14px; }
      .violation-dot { flex: none; width: 7px; height: 7px; border-radius: 50%; background: var(--bad); margin-top: 6px; }
      .violation-body { min-width: 0; }
      .violation-rule { font-family: var(--mono); font-size: 12.5px; font-weight: 500; color: var(--ink); }
      .violation-exp { font-size: 12.5px; color: var(--ink-soft); margin-top: 2px; line-height: 1.45; }
      .no-violations { display: flex; align-items: center; gap: 8px; border: 1px solid var(--line); border-radius: 10px; padding: 12px 14px; font-size: 12.5px; color: var(--ink-soft); }

      .advisory { margin-top: 22px; background: var(--bg); border: 1px solid var(--line); border-radius: 10px; padding: 14px 16px; }
      .advisory-label { font-size: 11.5px; font-weight: 600; letter-spacing: 0.02em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 9px; }
      .advisory-note { font-weight: 400; text-transform: none; letter-spacing: 0; }
      .advisory-list { display: flex; flex-direction: column; gap: 7px; }
      .advisory-item { display: flex; align-items: flex-start; gap: 9px; }
      .advisory-dot { flex: none; width: 6px; height: 6px; border-radius: 50%; background: var(--ink-muted); margin-top: 6px; }
      .advisory-flag { font-family: var(--mono); font-size: 12px; color: var(--ink-soft); }
      .advisory-exp { font-size: 12.5px; color: var(--ink-muted); }

      /* ---- JSON view ---- */
      .json-wrap { position: relative; padding: 20px 24px; animation: mp-fade .2s ease; }
      .json-copy {
        position: absolute; top: 12px; right: 14px; z-index: 1;
        font-family: var(--font); font-size: 11.5px; font-weight: 600; letter-spacing: 0.01em;
        color: var(--ink-soft); background: #fff; border: 1px solid var(--line);
        border-radius: 7px; padding: 5px 11px; cursor: pointer;
        transition: color .15s ease, border-color .15s ease, background .15s ease;
      }
      .json-copy:hover { color: var(--ink); border-color: var(--line-strong); }
      .json { font-family: var(--mono); font-size: 12.5px; line-height: 1.7; }
      .json-line { white-space: pre-wrap; word-break: break-word; }
      .stream-caret {
        display: inline-block; width: 7px; height: 14px; margin-left: 1px;
        background: var(--accent); vertical-align: text-bottom; animation: mp-blink 1s steps(2) infinite;
      }
      @keyframes mp-blink { 0%, 50% { opacity: 1; } 50.01%, 100% { opacity: 0; } }

      /* ---- Footer ---- */
      .output-footer {
        flex: none; border-top: 1px solid var(--line); padding: 12px 20px; display: flex; align-items: center; gap: 10px;
        font-family: var(--mono); font-size: 11.5px; color: var(--ink-muted); white-space: nowrap; flex-wrap: wrap;
      }
      .ok { display: inline-flex; align-items: center; gap: 6px; }
      .ok-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--good); }
      .footer-clear {
        margin-left: auto; font-family: var(--font); font-size: 11.5px; font-weight: 600;
        color: var(--ink-soft); background: #fff; border: 1px solid var(--line);
        border-radius: 7px; padding: 5px 12px; cursor: pointer;
        transition: color .15s ease, border-color .15s ease;
      }
      .footer-clear:hover { color: var(--ink); border-color: var(--line-strong); }
      .dot-sep { color: var(--line-strong); }

      /* ---- Checks drawer ---- */
      .topbar-actions { display: flex; align-items: center; gap: 10px; }
      .checks-btn { cursor: pointer; font-family: var(--font); }
      .checks-btn.active { color: #fff; background: var(--accent); border-color: var(--accent); box-shadow: 0 1px 3px rgba(79,70,229,0.35); }
      .checks-btn.active:hover { color: #fff; background: var(--accent-hover); border-color: var(--accent-hover); }
      .checks-btn svg { display: block; }

      .checks-open-link {
        margin-top: 4px; border: none; background: none; cursor: pointer;
        font-family: var(--font); font-size: 12.5px; font-weight: 500; color: var(--accent);
      }
      .checks-open-link:hover { color: var(--accent-hover); text-decoration: underline; }


      .drawer-backdrop {
        position: fixed; inset: 0; background: rgba(15,23,42,0.35); z-index: 40;
        opacity: 0; visibility: hidden; transition: opacity .25s ease, visibility .25s ease;
      }
      .drawer-backdrop.open { opacity: 1; visibility: visible; }
      .drawer {
        position: fixed; top: 0; right: 0; height: 100%; width: 400px; max-width: 90vw; z-index: 50;
        background: var(--surface); border-left: 1px solid var(--line);
        box-shadow: -20px 0 50px -24px rgba(15,23,42,0.35);
        display: flex; flex-direction: column;
        transform: translateX(100%); transition: transform .28s cubic-bezier(.2,.8,.2,1);
      }
      .drawer.open { transform: translateX(0); }
      .drawer-head {
        flex: none; display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;
        padding: 20px 22px; border-bottom: 1px solid var(--line);
      }
      .drawer-title { font-size: 16px; font-weight: 700; letter-spacing: -0.01em; color: var(--ink); }
      .drawer-sub { margin-top: 4px; font-size: 12.5px; color: var(--ink-soft); }
      .drawer-close {
        flex: none; width: 30px; height: 30px; border-radius: 8px; border: 1px solid var(--line);
        background: var(--surface); color: var(--ink-muted); cursor: pointer; font-size: 13px;
        display: flex; align-items: center; justify-content: center; transition: color .15s, background .15s, border-color .15s;
      }
      .drawer-close:hover { color: var(--ink); background: #f8fafc; border-color: var(--line-strong); }
      .drawer-body { flex: 1; min-height: 0; overflow-y: auto; padding: 18px 22px 28px; }
      .drawer-legend {
        margin: 0 0 16px; font-size: 12.5px; line-height: 1.7; color: var(--ink-soft);
      }
      .drawer-legend strong { color: var(--ink); font-weight: 600; }
      .drawer-group { margin-bottom: 18px; }
      .drawer-group:last-child { margin-bottom: 0; }
      .drawer-group-head {
        font-size: 11px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase;
        color: var(--ink-muted); margin-bottom: 10px;
      }
      .drawer-list { display: flex; flex-direction: column; gap: 8px; }
      .check {
        display: flex; align-items: flex-start; gap: 12px;
        border: 1px solid var(--line); border-radius: 10px; padding: 11px 13px; background: var(--surface);
      }
      .check-tier {
        flex: none; font-family: var(--mono); font-size: 10px; font-weight: 600;
        letter-spacing: 0.03em; text-transform: uppercase; border-radius: 6px; padding: 3px 7px;
        width: 64px; text-align: center; margin-top: 1px;
      }
      .check-body { min-width: 0; }
      .check-top { display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; }
      .check-label { font-size: 13px; font-weight: 600; color: var(--ink); line-height: 1.3; }
      .check-id { font-family: var(--mono); font-size: 11px; color: var(--ink-muted); }
      .check-examples { font-size: 12px; color: var(--ink-soft); line-height: 1.45; margin-top: 3px; }

      @media (max-width: 820px) {
        .app { height: auto; min-height: 100vh; overflow: visible; }
        .layout { flex-direction: column; }
        .input-panel { width: 100%; }
      }
    </style>
  </body>
</html>
